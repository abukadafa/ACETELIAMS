# ACETEL IAMS - Production Environment Template
# GENERATE SECURE SECRETS USING: openssl rand -base64 64

NODE_ENV=production
PORT=5000

# MongoDB (Hardened)
MONGO_ROOT_USER=acetel_admin
MONGO_ROOT_PASSWORD=YOUR_SECURE_ROOT_PASSWORD
MONGO_APP_USER=acetel_app
MONGO_APP_PASSWORD=YOUR_SECURE_APP_PASSWORD
MONGO_APP_DB=acetel_iams

# Redis
REDIS_PASSWORD=YOUR_SECURE_REDIS_PASSWORD

# Auth
JWT_SECRET=YOUR_SECURE_JWT_SECRET
JWT_REFRESH_SECRET=YOUR_SECURE_JWT_REFRESH_SECRET

# Frontend / Networking
FRONTEND_URL=http://192.168.x.x
API_URL=http://192.168.x.x/api
CORS_ORIGIN=http://192.168.x.x

# Local Storage (Institutional Document Storage)
UPLOAD_PATH=/app/uploads
MAX_FILE_SIZE=10485760 # 10MB in bytes

# Institutional Branding
LOGO_URL=https://acetel.nou.edu.ng/logo.png

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=no-reply@acetel.edu.ng
SMTP_PASS=YOUR_SMTP_PASSWORD
SMTP_FROM=ACETEL IAMS <no-reply@acetel.edu.ng>
