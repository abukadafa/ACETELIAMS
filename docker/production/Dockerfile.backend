# Build stage
FROM node:20-alpine AS builder

WORKDIR /app

COPY server/package*.json ./
RUN npm install

COPY server/ ./
RUN npm run build

# Production stage
FROM node:20-alpine

WORKDIR /app

COPY server/package*.json ./
RUN npm install --omit=dev

COPY --from=builder /app/dist ./dist
COPY server/src/scripts ./src/scripts

EXPOSE 5000

CMD ["node", "dist/index.js"]
