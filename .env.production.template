# ACETEL IAMS — Production Environment Template
# Replace all placeholders before deploying to Proxmox

NODE_ENV=production
PORT=5000
FRONTEND_URL=http://192.168.x.x

# MongoDB Configuration
# Root user (for first run / initialization)
MONGO_ROOT_USER=acetel_admin
MONGO_ROOT_PASSWORD=REPLACE_WITH_OPENSSL_RAND_BASE64_32

# Application user
MONGO_APP_USER=acetel_app
MONGO_APP_PASSWORD=REPLACE_WITH_OPENSSL_RAND_BASE64_32
MONGO_APP_DB=acetel_iams
MONGO_URI=mongodb://acetel_app:PASSWORD@mongo:27017/acetel_iams?authSource=acetel_iams

# Auth Secrets (Institutional Security)
JWT_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_64
JWT_REFRESH_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_64
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Storage & Backups
UPLOAD_DIR=/opt/acetel/uploads
BACKUP_DIR=/opt/acetel/backups
MAX_FILE_SIZE_MB=10

# Institutional Branding
LOGO_URL=https://acetel.nou.edu.ng/logo.png

# SMTP (Optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@acetel.edu.ng
